# LeetCode.cn cookie（从浏览器复制，建议仅包含必要字段）
# 示例：LEETCODE_SESSION=xxxx; csrftoken=yyyy
LEETCODE_COOKIE=

# 可选：默认语言（python3 / cpp / java 等）
DEFAULT_LANG=python3

# 可选：默认每次拉取题目数量
DEFAULT_LIMIT=10

# AI API 配置（支持多种供应商）
# 默认供应商和模型
AI_PROVIDER=openai
AI_BASE_URL=

# OpenAI API
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.3

# DeepSeek API
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v3.2

# Google Gemini API
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.0-pro

# Anthropic Claude API
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-4-opus
